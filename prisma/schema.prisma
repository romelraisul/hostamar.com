
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- NextAuth PrismaAdapter models ---
// Following canonical @auth/prisma-adapter schema for password-reset (VerificationToken)
// and OAuth account linking (Account/Session). Customer table kept untouched so existing users continue to work.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User/Customer Model
model Customer {
  customerId   String   @unique @default(cuid())
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  emailVerified DateTime?
  resetToken    String?
  resetTokenExpiry DateTime?
  role          String   @default("customer") // "customer" | "admin" | "superadmin"
  phone         String?
  stage        String?   @default("lead")
  source       String?   @default("website")
  score        Int?      @default(0)
  credits      Int       @default(0)
  notes        String?
  referralCode String?   @unique
  referredBy   String?
  referralBonus Float?  @default(0)
  balance       Float?   @default(0)

  // relationships
  business      Business?
  subscriptions Subscription[]
  videos        Video[]
  services      Service[]
  payments      Payment[]
  transactions  Transaction[]
  orders        Order[]
  notifications    Notification[]
  leads         Lead[]
  referralsMade    Referral[]   @relation("ReferrerReferrals")
  referralsReceived Referral[]  @relation("ReferredReferrals")
  videoQueues      VideoQueue[]
  activityLogs     ActivityLog[]
  campaigns        Campaign[]
  userProgress     UserProgress[]
  previews         Preview[]
  conversations     Conversation[]
  gameBalances      GameBalance[]
  gameSpins         GameSpin[]

  // Twitter OAuth 2.0
  twitterAccessToken   String?
  twitterAccessTokenExpiry DateTime?
  twitterUserId        String?
  twitterUsername      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Business {
  id            String   @id @default(cuid())
  customerId    String   @unique
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name          String
  industry      String
  description   String?
  website       String?
  logo          String?
  brandColor    String  @default("#3B82F6")

  facebook      String?
  instagram     String?
  youtube       String?
  tiktok        String?

  videoFrequency String  @default("daily")
  videoTopics    String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Subscription {
  id            String   @id @default(cuid())
  customerId    String   @unique
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  plan          String
  status        String   @default("active")

  videosPerMonth Int     @default(10)
  storageGB     Int      @default(5)

  price         Float
  currency      String   @default("BDT")
  billingCycle  String   @default("monthly")
  nextBillingDate DateTime

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Video {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  prompt        String?
  script        String?
  templateId    String?

  duration      Int
  format        String  @default("mp4")
  resolution    String  @default("1080p")
  fileSize      Int?

  url           String?
  thumbnailUrl  String?

  topic         String?
  language      String  @default("bn")
  status        String  @default("processing")

  downloads     Int     @default(0)
  views         Int     @default(0)
  shares         Int     @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
  @@index([createdAt])
}

model Preview {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  subtitles     Subtitle[]

  videoId       String?
  title         String?
  description   String?
  duration      Int?
  prompt        String?
  style         String?
  mood          String?
  topic         String?
  script        String?
  status        String  @default("pending")
  renderStatus  String?
  renderError   String?
  errorMessage  String?
  thumbnailUrl  String?
  videoUrl      String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
}

model Subtitle {
  id         String   @id @default(cuid())
  previewId  String?
  preview    Preview? @relation(fields: [previewId], references: [id], onDelete: Cascade)

  videoId    String?
  language   String?  @default("bn")
  content    String?
  timestamps Json?
  text       String?
  start      Float    @default(0)
  end        Float    @default(0)

  createdAt  DateTime @default(now())
}

model Service {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type          String
  name          String
  status        String   @default("active")

  specs         String?
  credentials   String

  serverIp      String?
  serverId      String?

  price         Float
  billingCycle  String   @default("monthly")
  createdAt     DateTime @default(now())
  expiresAt     DateTime?
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
}

model VideoQueue {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  topic         String
  priority      Int      @default(5)
  status        String   @default("pending")
  type          String?  @default("video")

  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)
  error         String?

  renderStatus  String?
  renderError   String?
  videoUrl      String?
  thumbnailUrl  String?
  videoId       String?

  createdAt     DateTime @default(now())
  processedAt   DateTime?

  @@index([status, priority])
}

model ActivityLog {
  id        String   @id @default(cuid())
  customerId String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  action        String
  description   String
  metadata      String?
  ipAddress     String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([createdAt])
}

model Payment {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  method        String
  amount        Float
  currency      String   @default("BDT")
  status        String   @default("pending")
  transactionId String?  @unique

  walletAddress String?
  usdtTxHash    String?

  planName      String?
  billingPeriod String?
  startsAt      DateTime?
  endsAt        DateTime?

  webhookSent   Boolean  @default(false)
  invoiceUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
  @@index([transactionId])
  @@index([createdAt])
}

model Transaction {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  amount        Float
  currency      String   @default("BDT")
  status        String   @default("pending")
  gateway       String
  gatewayTrxId  String?
  cardType      String?
  cardBrand     String?
  sessionKey    String?
  videoPackage  String?
  creditsAdded  Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
  @@index([gatewayTrxId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  customerId String
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?

  createdAt DateTime @default(now())

  @@index([customerId, createdAt])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    Customer @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String
  referred    Customer @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: Cascade)
  status      String   @default("PENDING")
  bonusAmount Float

  createdAt   DateTime @default(now())

  @@index([referrerId])
  @@index([referredId])
}

model Order {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  plan        String
  amount      Float
  status      String   @default("pending")
  currency    String   @default("BDT")

  createdAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId, status])
  @@index([createdAt])
}

model Lead {
  id          String   @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name        String
  email       String?
  phone       String?
  company     String?
  source      String  @default("manual")
  status      String  @default("new")
  score       Int     @default(0)
  tags        String?
  notes       String?

  contactedAt   DateTime?
  lastContactAt DateTime?
  attemptCount  Int       @default(0)
  convertedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs        LeadLog[]
  followUps   FollowUp[]
  outreachLogs OutreachLog[]

  @@index([status])
  @@index([source])
}

model LeadLog {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  action    String
  notes     String?
  outcome   String?

  createdAt DateTime @default(now())

  @@index([leadId])
}

model Campaign {
  id            String   @id @default(cuid())
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  name          String
  description   String?
  type          String
  channel       String?
  targetCount   Int      @default(0)
  startDate     DateTime?
  endDate       DateTime?

  status      String  @default("draft")
  reachedCount  Int     @default(0)
  respondedCount Int     @default(0)
  convertedCount Int     @default(0)

  createdAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model FollowUp {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId  String?

  followUpType  String
  scheduledFor  DateTime
  notes         String?
  priority      String  @default("medium")
  status      String  @default("pending")
  completedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([scheduledFor])
  @@index([status])
}

model OutreachLog {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId  String?

  channel     String
  direction   String  @default("outbound")
  subject     String?
  message     String?
  status      String
  response    String?
  outcome     String?

  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model PipelineSnapshot {
  id            String   @id @default(cuid())

  totalLeads    Int
  contacted     Int
  interested    Int
  converted     Int
  paying        Int
  totalRevenue  Float

  createdAt     DateTime @default(now())
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        Customer @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  lessonId    String
  completed   Boolean  @default(false)
  quizScore   Int?     @default(0)

  createdAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, courseId, lessonId], name: "userId_courseId_lessonId")
  @@index([userId])
  @@index([courseId])
  @@index([courseId, completed])
}

enum BetaStatus {
  PENDING
  ACTIVE
  USED
  EXPIRED
}

model RateLimitEvent {
  id        String   @id @default(cuid())
  bucket    String   // "ip:path" hash
  ip        String
  path      String
  method    String   @default("GET")
  createdAt DateTime @default(now())

  @@index([bucket, createdAt])
  @@index([ip, createdAt])
}

model BetaInvite {
  id              String     @id @default(cuid())
  code            String     @unique
  email           String
  name            String
  phone           String?
  status          BetaStatus @default(PENDING)
  discountPercent Float      @default(10)

  usedAt          DateTime?
  expiresAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, createdAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  role           String
  content        String
  model          String?
  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
}

model GameBalance {
  id         String    @id @default(cuid())
  customerId String    @unique
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  credits    Int       @default(1000)
  balance    Float     @default(1000)
  mode       String    @default("demo")
  updatedAt  DateTime  @updatedAt

  spins      GameSpin[]

  @@index([customerId])
}
model GameSpin {
  id           String    @id @default(cuid())
  balanceId    String
  customerId   String
  balance      GameBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  bet          Int
  reels        String[]
  won          Boolean   @default(false)
  multiplier   Int       @default(0)
  amount       Float     @default(0)
  message      String?
  createdAt    DateTime  @default(now())

  @@index([customerId, createdAt])
  @@index([balanceId, createdAt])
}
