{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Launch tracking record (one per shop)",
  "type": "object",
  "required": ["shopName", "day1SentAt"],
  "properties": {
    "shopName": { "type": "string" },
    "ownerName": { "type": "string" },
    "topProduct": { "type": "string" },
    "personalizedVideoUrl": { "type": "string" },
    "loomUrl": { "type": "string" },
    "day1SentAt": { "type": "string", "format": "date-time" },
    "opened": { "type": "boolean" },
    "replied": { "type": "boolean" },
    "loomViewed": { "type": "boolean" },
    "checkoutStarted": { "type": "boolean" },
    "paidAt": { "type": "string", "format": "date-time" },
    "orgId": { "type": "string", "description": "Organization.id once they purchase (isolation FK)" },
    "mrr": { "type": "number", "description": "3500 per Business plan" },
    "notes": { "type": "string" }
  },
  "example": {
    "shopName": "REAL-SHOP-NAME",
    "ownerName": "Karim",
    "topProduct": "Cotton Saree",
    "personalizedVideoUrl": "https://hostamar.com/videos/abc123",
    "loomUrl": "https://loom.com/share/xyz",
    "day1SentAt": "2026-07-13T10:00:00+06:00",
    "opened": true,
    "replied": false,
    "loomViewed": false,
    "checkoutStarted": false,
    "paidAt": null,
    "orgId": null,
    "mrr": 0
  }
}
