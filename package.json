{
  "name": "hostamar-platform",
  "version": "1.0.0",
  "description": "Hostamar.com - Cloud Hosting + AI Video Marketing Platform",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production prisma generate && NODE_ENV=production next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "vercel-deploy": "vercel --prod --yes",
    "browser:health": "echo \"Camofox health: check http://localhost:9377/health\"",
    "browser:auto": "echo \"Run camofox-hostamar.mjs for browser automation\"",
    "browser:api": "echo \"Camofox API docs at http://localhost:9377\"",
    "cleanup": "rm -rf .next/ out/ dist/ && echo \"Cleaned\"",
    "typecheck": "npx tsc --noEmit --skipLibCheck",
    "make": "make"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.577.0",
    "@aws-sdk/s3-request-presigner": "^3.577.0",
    "@boxyhq/saml-jackson": "^1.52.2",
    "@fontsource/noto-sans-bengali": "^5.2.11",
    "@monaco-editor/react": "^4.7.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.7.0",
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.3",
    "fluent-ffmpeg": "^2.1.3",
    "inngest": "^4.12.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "lucide-react": "^0.294.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "openai": "^6.37.0",
    "posthog-js": "^1.376.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.35",
    "prisma": "^5.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vercel": "^54.6.1"
  }
}
