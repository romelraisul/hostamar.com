{
  "title": "Hostamar Overview",
  "uid": "hostamar-overview",
  "tags": ["hostamar", "overview"],
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests Rate",
      "type": "graph",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(hostamar_http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 4},
      "targets": [
        {
          "expr": "hostamar_uptime_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 3,
      "title": "Prometheus Targets Up",
      "type": "stat",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 4},
      "targets": [
        {
          "expr": "sum(up) by (job)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Container CPU Usage",
      "type": "graph",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{container!=\"\"}[1m])",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Container Memory Usage",
      "type": "graph",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "container_memory_usage_bytes{container!=\"\"}",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis Commands Rate",
      "type": "graph",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(redis_commands_total[1m])",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Ollama Models Loaded",
      "type": "stat",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 4},
      "targets": [
        {
          "expr": "ollama_models_loaded",
          "refId": "A"
        }
      ]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "schemaVersion": 38,
  "version": 1
}