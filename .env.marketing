# =============================================================================
# HOSTAMAR MARKETING ENGINE — Environment Configuration
# =============================================================================
# Copy this file to .env.marketing and fill in your actual values.
# The script loads this automatically on startup (via python-dotenv).
#
# Usage:
#   cp .env.marketing.template .env.marketing
#   # edit .env.marketing with your real keys
#   python3 marketing-engine.py
# =============================================================================

# ---------------------------------------------------------------------------
# FACEBOOK — Page ID and Access Token for Graph API
# ---------------------------------------------------------------------------
# FB_PAGE_ID:   Your Facebook Page's numeric ID
#               (found in Page Settings → Page Info → Page ID)
# FB_ACCESS_TOKEN: A never-expiring Page Access Token
#               (generate at developers.facebook.com → Tools → Graph API Explorer)
FB_PAGE_ID=
FB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# FACEBOOK GROUPS — IDs for each group you want to post to
# ---------------------------------------------------------------------------
# Find a group's ID by looking at its URL:
#   https://facebook.com/groups/1234567890  →  id = 1234567890
# Leave blank ("") to skip posting to that group.
FACEBOOK_GROUP_1=
FACEBOOK_GROUP_2=
FACEBOOK_GROUP_3=
FACEBOOK_GROUP_4=
FACEBOOK_GROUP_5=

# ---------------------------------------------------------------------------
# YOUTUBE — API key for YouTube Data API v3
# ---------------------------------------------------------------------------
# Generate at https://console.cloud.google.com → APIs & Services → Credentials
YT_API_KEY=

# ---------------------------------------------------------------------------
# WHATSAPP — API key for WhatsApp Business Cloud API
# ---------------------------------------------------------------------------
WA_API_KEY=

# ---------------------------------------------------------------------------
# EMAIL — SMTP credentials for sending campaigns
# ---------------------------------------------------------------------------
# SMTP_HOST:     Your mail server (default: smtp.gmail.com)
# SMTP_PORT:     Port (default: 587 for TLS)
# EMAIL_FROM:    Sender email address
# EMAIL_PASSWORD: App password or SMTP password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=

# ---------------------------------------------------------------------------
# OUTPUT — where generated content files land
# ---------------------------------------------------------------------------
# Defaults to ./marketing-output/ (relative to marketing-engine.py)
# Set an absolute path here to override.
# MARKETING_OUTPUT_DIR=
