# video-pipeline env (copy to .env). NO secrets here — real values go in your shell/CI.
REDIS_URL=redis://redis:6379/0

# ComfyUI endpoints
COMFY_MAIN_URL=http://comfyui-main:8188
COMFY_LITE_URL=http://comfyui-lite:8189

# Gateway auth — set a strong random value in prod
VIDEO_KEY=change-me-in-prod

# bKash (optional paywall gate; stubbed when empty)
BKASH_KEY=

# Cloudflare R2 (or MinIO in dev). R2_PUBLIC_URL is the edge base for public reads.
R2_ENDPOINT=http://minio:9000
R2_KEY=minioadmin
R2_PASS=minioadmin
R2_BUCKET=hostamar-videos
R2_PUBLIC_URL=http://localhost:9000/hostamar-videos
R2_TTL=604800

# HuggingFace token (needed for gated repos: LTX-2, Chatterbox)
HF_TOKEN=

# Where to POST when a job finishes (optional)
WEBHOOK_URL=
