BKASH_VERIFY_URL=https://partner.bka.sh/v1.2.0-beta/payment/verify
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_ENVIRONMENT=sandbox

# Nagad payment gateway
