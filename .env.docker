# Hostamar Docker Production Environment
# Auto-generated for local Docker deployment

# Database (Docker compose service name)
DATABASE_URL=postgresql://hostamar:hostamar@postgres:5432/hostamar
REDIS_URL=redis://redis:6379

# Auth
NEXTAUTH_SECRET=hostamar-docker-local-dev-secret-2026
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=hostamar-docker-jwt-local-2026

# Site
NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://hostamar.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@hostamar.com
NEXT_PUBLIC_CONTACT_EMAIL=admin@hostamar.com

# AI
OPENAI_API_KEY=sk-placeholder
ELEVENLABS_API_KEY=placeholder

# Storage (local MinIO-style - uses filesystem for dev)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin
R2_BUCKET=hostamar-videos
R2_PUBLIC_URL=http://localhost:9000/hostamar-videos

# Ollama (Docker host)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=hermes3:latest

# Monitoring
SENTRY_ORG=hostamar
SENTRY_PROJECT=hostamar

# PostgreSQL defaults (used by postgres service)
POSTGRES_USER=hostamar
POSTGRES_PASSWORD=hostamar
POSTGRES_DB=hostamar
