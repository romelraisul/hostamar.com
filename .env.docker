# SMTP — for local dev: use mailpit (see docker-compose). For prod, set
# SMTP_HOST/SMTP_USER/SMTP_PASS/SMTP_FROM on Railway. The app reads these
# env vars and nodemailer handles TLS automatically (port 465 = SSL, 587 = STARTTLS).
SMTP_HOST=mailpit
SMTP_PORT=11125
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hostamar.com

# Permanent failover architecture:
#   hostamar.com -> Vercel
#   local.hostamar.com -> tunnel when local is healthy, Vercel fallback when down
