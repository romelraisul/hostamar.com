# Hostamar Docker Production Environment
# Auto-generated for local Docker deployment

# Database (Docker compose service name)
DATABASE_URL=postgresql://hostamar:hostamar@postgres:5432/hostamar
# Primary: in-network Redis (hostamar-redis container)
# Fallback: Upstash REST (when WSL Redis via CF tunnel is unreachable from cloud workers)
# See lib/redis-failover.ts for the watchdog logic.
REDIS_URL=redis://redis:6379
# Upstash REST endpoint (URL value is not sensitive — redeploying the token at Upstash will replace this).
UPSTASH_REDIS_REST_URL=https://growing-mammal-127269.upstash.io
# Token: rotate after this paste incident; do NOT commit a real value here.
UPSTASH_REDIS_REST_TOKEN=__ROTATE_AND_REPLACE__
# Heartbeat tuning for the failover watchdog.
REDIS_HEARTBEAT_MS=10000
REDIS_MAX_FAILS=3


# Auth
NEXTAUTH_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=https://hostamar.com
NEXT_PUBLIC_APP_URL=https://hostamar.com

# AI
OPENAI_API_KEY=plac...er
ELEVENLABS_API_KEY=plac...r
# OLLAMA_HOST points at hostamar-model (OpenAI/OpenClaw compatible proxy on :8000).
# OLLAMA_MODEL permanently qwen3.6:27b. OLLAMA_FAST=qwen3.0.6b is the low-latency fallback.
OLLAMA_HOST=http://hostamar-model:8000
OLLAMA_MODEL=qwen3.6:27b
OLLAMA_FAST=qwen3:0.6b
OLLAMA_RAW_HOST=http://hostamar-ollama:11434

# Storage (local MinIO-style - uses filesystem for dev)
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin
R2_BUCKET=hostamar-videos
R2_PUBLIC_URL=http://localhost:9000/hostamar-videos

# Monitoring
SENTRY_ORG=hostamar
SENTRY_PROJECT=hostamar
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# PostgreSQL defaults (used by postgres service)
POSTGRES_USER=hostamar
POSTGRES_PASSWORD=hostamar
POSTGRES_DB=hostamar
