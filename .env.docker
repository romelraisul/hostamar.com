# Hostamar Docker Production Environment

# Database (local host PostgreSQL for migrations)
DATABASE_URL=postgresql://hostamar:***@postgres:5432/hostamar
REDIS_URL=redis://redis:6379

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=hostamar-docker-local-dev-secret-2026
NEXT_PUBLIC_CONTACT_EMAIL=admin@hostamar.com

# AI
OPENAI_API_KEY=
ELEVENLABS_API_KEY=placeholder

# Storage (local MinIO-style)
R2_ENDPOINT=http://hostamar-minio:9000
R2_ACCESS_KEY=minioadmin
R2_SECRET_KEY=minioadmin
R2_BUCKET=hostamar-videos
R2_PUBLIC_URL=http://localhost:9000/hostamar-videos

# Ollama
OLLAMA_HOST=http://hostamar-ollama:11434
OLLAMA_BASE_URL=http://hostamar-ollama:11434
OLLAMA_MODEL=hermes3:latest

# Monitoring
SENTRY_ORG=hostamar
SENTRY_PROJECT=hostamar

# PostgreSQL defaults
POSTGRES_USER=hostamar
POSTGRES_PASSWORD=hostamar123
POSTGRES_DB=hostamar
