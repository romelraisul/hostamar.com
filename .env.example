# Hostamar environment configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:***@host:5432/hostamar

# Auth (NextAuth.js)
NEXTAUTH_SECRET=change...n
NEXTAUTH_URL=http:/...3000

# Worker
WORKER_SHARED_SECRET=change-me-to-a-random-string

# Analytics (pick one: ga4 or plausible)
NEXT_PUBLIC_ANALYTICS_PROVIDER=ga4
NEXT_PUBLIC_GA4_ID=G-961Q6CX4GN

# Stripe (for billing features)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (create products in Stripe Dashboard first)
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...

# Feature flags (optional)
# NEXT_PUBLIC_FEATURE_FLAGS={"onboarding_v2":"v2"}
