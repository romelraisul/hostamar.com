# =============================================================================
# Hostamar — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are marked with [REQUIRED].
# All others are optional and have safe defaults.

# =============================================================================
# CORE — Database & App Environment
# =============================================================================

# [REQUIRED] PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/hostamar

# Node environment: development | production | test
NODE_ENV=development


# =============================================================================
# AUTHENTICATION — NextAuth.js & JWT
# =============================================================================

# [REQUIRED] NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# [REQUIRED] Application URL (used for callbacks, emails, CORS)
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here


# =============================================================================
# SMTP / EMAIL — Transactional Emails
# =============================================================================

# SMTP server hostname (e.g., smtp.sendgrid.net, smtp.gmail.com)
SMTP_HOST=

# SMTP server port (default: 587 for STARTTLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username (often the full email address)
SMTP_USER=

# SMTP authentication password or app-specific password
SMTP_PASS=

# Sender email address shown in outgoing emails
SMTP_FROM=noreply@hostamar.com


# =============================================================================
# PUBLIC SITE / SEO
# =============================================================================

# Public-facing site URL (used in SEO metadata, sitemap, robots.txt)
NEXT_PUBLIC_SITE_URL=https://hostamar.com

# Contact/support email addresses shown in UI
NEXT_PUBLIC_SUPPORT_EMAIL=support@hostamar.com
NEXT_PUBLIC_CONTACT_EMAIL=admin@hostamar.com

# Google Search Console site verification token
GOOGLE_SITE_VERIFICATION=


# =============================================================================
# AI / VIDEO GENERATION — OpenAI, GitHub Models, ElevenLabs
# =============================================================================

# OpenAI API key (used for video script generation & topic suggestions)
# Falls back to GITHUB_TOKEN if not set via GitHub Models Azure endpoint
OPENAI_API_KEY=

# GitHub personal access token (used as API key for GitHub Models / Azure AI)
# baseURL hardcoded to: https://models.inference.ai.azure.com
GITHUB_TOKEN=

# ElevenLabs API key for premium AI voice-over generation (Bengali supported)
ELEVENLABS_API_KEY=

# Set to 'true' to use Google Cloud Text-to-Speech instead of ElevenLabs
USE_GOOGLE_TTS=false


# =============================================================================
# OBJECT STORAGE — MinIO / S3-compatible (for video files)
# =============================================================================

# MinIO or S3-compatible object storage endpoint
MINIO_ENDPOINT=http://localhost:9000

# MinIO/S3 access key
MINIO_ACCESS_KEY=

# MinIO/S3 secret key
MINIO_SECRET_KEY=


# =============================================================================
# BANGLADESH PAYMENT GATEWAYS
# =============================================================================

# -- bKash Merchant API (Tokenized Checkout) --------------------------------

# bKash API base URL (sandbox vs production)
BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# bKash merchant API key (app_key)
BKASH_API_KEY=

# bKash merchant API secret (app_secret)
BKASH_API_SECRET=

# bKash merchant number (displayed to customers for manual payment)
BKASH_NUMBER=01XXXXXXXXX

# -- Nagad Merchant API -----------------------------------------------------

# Nagad API base URL
NAGAD_API_URL=https://api.nagad.com.bd

# Nagad merchant ID
NAGAD_MERCHANT_ID=

# Nagad merchant API key
NAGAD_API_KEY=

# Nagad merchant number (displayed to customers)
NAGAD_NUMBER=01XXXXXXXXX

# -- Rocket (DBBL) Payment --------------------------------------------------

# Rocket merchant number (displayed to customers)
ROCKET_NUMBER=01XXXXXXXXX


# =============================================================================
# CRYPTO PAYMENT — USDT (TRC-20 / BEP-20)
# =============================================================================

# USDT wallet address for receiving crypto payments
USDT_WALLET_ADDRESS=0x16Bfd806297feaC12FC4b8A6c95079E8aADeC858

# USDT to BDT exchange rate (used for amount conversion)
USDT_BDT_RATE=110


# =============================================================================
# PAYMENT WEBHOOK — Server-side verification
# =============================================================================

# Secret key used to verify incoming payment webhook signatures
# Must match the secret configured on your payment provider's webhook dashboard
PAYMENT_WEBHOOK_SECRET=


# =============================================================================
# SMS & WHATSAPP NOTIFICATIONS
# =============================================================================

# SMS API configuration (Hostamar SMS Gateway or any SMS API)
SMS_API_URL=https://api.hostamar.com/sms/send
SMS_API_KEY=
SMS_SENDER_ID=HOSTAMAR

# WhatsApp Cloud API (Meta/Facebook)
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=


# =============================================================================
# SOCIAL MEDIA INTEGRATION — Auto-Posting
# =============================================================================

# -- Facebook / Meta Graph API ----------------------------------------------

# Facebook page ID to post to
FB_PAGE_ID=

# Facebook page access token (long-lived, from Meta Developer Console)
FB_ACCESS_TOKEN=

# Facebook page display name (for status endpoint)
FB_PAGE_NAME=

# -- Twitter / X API v2 -----------------------------------------------------

# Twitter/X bearer token (OAuth 2.0) for posting tweets
TWITTER_BEARER_TOKEN=

# Twitter/X handle (for status endpoint display)
TWITTER_HANDLE=

# -- LinkedIn API -----------------------------------------------------------

# LinkedIn access token (OAuth 2.0) for posting
LINKEDIN_ACCESS_TOKEN=

# LinkedIn person/profile ID (URN format: urn:li:person:xxxxx)
LINKEDIN_PERSON_ID=

# LinkedIn profile display name (for status endpoint)
LINKEDIN_PROFILE=


# =============================================================================
# CLOUDFLARE — DNS & Deployment
# =============================================================================

# Cloudflare API token (needs DNS:Edit permission)
CLOUDFLARE_API_TOKEN=

# Cloudflare zone ID (found in Cloudflare dashboard > Overview)
CLOUDFLARE_ZONE_ID=


# =============================================================================
# DISCORD — Community Webhook
# =============================================================================

# Discord webhook URL for community/OSSU notifications
DISCORD_WEBHOOK_URL=


# =============================================================================
# DEPLOYMENT — Vercel
# =============================================================================

# Vercel deployment token (from Vercel dashboard > Settings > Tokens)
VERCEL_TOKEN=

# Vercel team/organization ID
VERCEL_ORG_ID=

# Vercel project ID
VERCEL_PROJECT_ID=


# =============================================================================
# SCRIPTS / LOAD TESTING — CLI Tools
# =============================================================================

# Target URL for load testing (scripts/load-test.ts)
TARGET_URL=http://localhost:3000

# Concurrent virtual users for load testing (default: 50)
CONCURRENT_USERS=50

# Requests per user for load testing (default: 20)
REQUESTS_PER_USER=20

# Test duration in seconds for load testing (default: 60)
TEST_DURATION=60

# Headless browser mode for automation scripts (true|false)
HEADLESS=true

# Site URL override for automation scripts (scripts/browser-automation.js)
SITE_URL=https://hostamar.com


# =============================================================================
# EVAL / BENCHMARKING — AI Model Evaluation
# =============================================================================

# Azure AI Foundry project endpoint URL
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=

# Comma-separated list of models to evaluate (default: gpt-5,gpt-4.1-mini,phi-4)
EVAL_MODELS=gpt-5,gpt-4.1-mini,phi-4

# Set to 'true' to run evaluation in mock mode (no real API calls)
MOCK_MODE=false


# =============================================================================
# LEGACY / PAYMENT-VERIFIER SCRIPT
# =============================================================================

# bKash credentials for payment-verifier script
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=

# Nagad credentials for payment-verifier script
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=


# =============================================================================
# CAMOFOX (sub-project: Browser Automation) — see camofox/.env.example
# =============================================================================
# Camofox is a separate browser automation module included in this repo.
# See camofox/lib/config.js for all available env vars, including:
#   CAMOFOX_PORT, CAMOFOX_ADMIN_KEY, CAMOFOX_API_KEY, CAMOFOX_ACCESS_KEY
#   CAMOFOX_PROFILE_DIR, CAMOFOX_COOKIES_DIR, CAMOFOX_TRACES_DIR
#   CAMOFOX_EXECUTABLE_PATH, CAMOUFOX_EXECUTABLE, CAMOUFOX_EXECUTABLE_PATH
#   CAMOFOX_CRASH_REPORT_ENABLED, CAMOFOX_CRASH_REPORT_URL
#   PROXY_PROVIDER, PROXY_HOST, PROXY_PORT, PROXY_USERNAME, PROXY_PASSWORD
#   ENABLE_VNC, VNC_RESOLUTION, VNC_PASSWORD, VNC_PORT, NOVNC_PORT
#   FLY_MACHINE_ID, FLY_APP_NAME, FLY_API_TOKEN
#   PROMETHEUS_ENABLED, HANDLER_TIMEOUT_MS, MAX_SESSIONS, etc.
# Refer to camofox/lib/config.js for the full list.
# =============================================================================
