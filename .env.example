# ============================================================================
# Hostamar — example environment (copy to .env.local / .env.docker / .env.prod)
# NEVER commit real secrets. Add LIVEKIT_API_SECRET / COTURN_PASSWORD to
# 1Password / Doppler and inject at deploy time.
# ============================================================================

# --- Core ---
DATABASE_URL=postgresql://hostamar:hostamar@localhost:5432/hostamar
REDIS_URL=redis://localhost:6379
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Voice Agent (7th product) — LiveKit SFU ---
# Public WS URL the browser connects to (Cloudflare Tunnel -> livekit:7880).
LIVEKIT_URL=wss://voice.hostamar.com
# Internal URL used only when the app runs inside the Docker stack.
LIVEKIT_INTERNAL_URL=ws://livekit:7880
# Server-only secrets — MUST NOT be exposed to the client bundle.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=
# RTC media port range (UDP) — open these in the firewall.
LIVEKIT_RTC_PORT_RANGE=7882-7887
# TURN hostname for NAT traversal (Coturn).
LIVEKIT_TURN_DOMAIN=turn.hostamar.com
# Force TCP fallback (set true if ISP blocks UDP).
LIVEKIT_FORCE_TCP=false

# --- Production self-host (docker-compose.prod.yml) ---
VPS_PUBLIC_IP=
COTURN_PASSWORD=
# TURN static auth secret (32+ random) — preferred over COTURN_PASSWORD for
# WebRTC/LiveKit TURN credentials. Generate: openssl rand -hex 32
TURN_STATIC_AUTH_SECRET=
# TURN realm/domain (must match the Let's Encrypt cert in ./certs).
TURN_DOMAIN=turn.hostamar.com
# Local cert dir mounted into coturn + livekit (gitignored; populated by
# scripts/rotate-turn-cert.sh from /etc/letsencrypt/live/<TURN_DOMAIN>).
CERT_DIR=./certs

# --- Inngest (self-hosted) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Optional integrations ---
TELEGRAM_BOT_TOKEN=
OLLAMA_HOST=http://localhost:11434
