# =============================================================================
# Hostamar — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# [REQUIRED] — Database URL. Choose based on where you run:
#   - LOCAL DEVELOPMENT (laptop):  postgresql://hostamar:hostamar@localhost:5432/hostamar
#   - DOCKER COMPOSE (inside container): postgresql://hostamar:hostamar@postgres:5432/hostamar
#   - VERCEL / FAILOVER:            postgresql://...@ep-spring-frog-aoikue4i-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#   - RAILWAY / FAILOVER:           postgresql://postgres:***@postgres.railway.internal:5432/railway?sslmode=require
#
# First-run schema recommended: npx prisma migrate deploy
DATABASE_URL=postgresql://hostamar:hostamar@localhost:5432/hostamar

# Node environment: development | production | test
NODE_ENV=development

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional defaults
REDIS_URL=redis://localhost:6379
OLLAMA_HOST=http://hostamar-model:8000
