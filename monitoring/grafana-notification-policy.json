{
  "receiver": "slack-hostamar",
  "group_by": ["alertname", "severity"],
  "group_wait": "30s",
  "group_interval": "5m",
  "repeat_interval": "4h",
  "routes": [
    {
      "receiver": "slack-hostamar",
      "object_matchers": [["severity", "=", "critical"]],
      "group_wait": "10s",
      "group_interval": "1m",
      "repeat_interval": "15m"
    },
    {
      "receiver": "slack-hostamar",
      "object_matchers": [["severity", "=", "warning"]],
      "group_wait": "30s",
      "group_interval": "5m",
      "repeat_interval": "1h"
    },
    {
      "receiver": "slack-hostamar",
      "object_matchers": [["severity", "=", "info"]],
      "group_wait": "1m",
      "group_interval": "15m",
      "repeat_interval": "6h"
    }
  ]
}
