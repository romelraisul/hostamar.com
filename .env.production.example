# =============================================================================
# Hostamar — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in your values:
#   cp .env.production.example .env.production
# Then deploy:
#   docker compose -f docker-compose.prod.yml up -d --build
# =============================================================================

# ---------------------------------------------------------------------------
# Database — PostgreSQL (use Neon connection string in production)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/hostamar?sslmode=require"

# ---------------------------------------------------------------------------
# Redis — BullMQ job queue backend
# ---------------------------------------------------------------------------
REDIS_URL="redis://redis:6379"

# ---------------------------------------------------------------------------
# Cloudflare R2 — Object storage for generated videos
# ---------------------------------------------------------------------------
R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
R2_ACCESS_KEY="your-r2-access-key"
R2_SECRET_KEY="your-r2-secret-key"
R2_BUCKET="hostamar-videos"
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"

# ---------------------------------------------------------------------------
# Replicate — AI image generation (flux-schnell)
# ---------------------------------------------------------------------------
REPLICATE_API_KEY="r8_xxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# NextAuth — Authentication
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://hostamar.com"
NEXT_PUBLIC_APP_URL="https://hostamar.com"

# ---------------------------------------------------------------------------
# Sentry — Error tracking (optional)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""

# ---------------------------------------------------------------------------
# PostHog — Product analytics (optional)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ---------------------------------------------------------------------------
# OpenAI — AI features (optional, used for script generation etc.)
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Hosted AI inference fallback (OpenAI-compatible providers)
# Examples: Groq, OpenRouter, Together.ai
FALLBACK_API_URL=
FALLBACK_API_KEY=
FALLBACK_MODEL=

# ---------------------------------------------------------------------------
# PostgreSQL local credentials (used by docker-compose.prod.yml when running
# the local postgres service instead of Neon)
# ---------------------------------------------------------------------------
POSTGRES_USER=hostamar
POSTGRES_PASSWORD=hostamar
POSTGRES_DB=hostamar
